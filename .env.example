# Base domain for short URLs
# Set this to the API Gateway URL from `cdk deploy` output
# Example: https://abc123.execute-api.us-east-1.amazonaws.com
BASE_DOMAIN=

# DynamoDB table name (from cdk deploy output)
TABLE_NAME=

# Redis host (ElastiCache endpoint from cdk deploy output)
REDIS_HOST=

# Redis port (default 6379)
REDIS_PORT=6379

# Redis TTL in seconds for cached aliases (default 3600 = 1 hour)
REDIS_TTL=3600

# AWS region
AWS_REGION=us-east-1

# Short alias length in characters (default 6 → 62^6 = ~56 billion aliases)
ALIAS_LENGTH=6
